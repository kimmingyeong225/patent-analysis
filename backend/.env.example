# 로컬 개발용 환경변수 템플릿. 실제 키는 .env 에 복사해 채워넣으세요 (.env는 커밋 금지).

# KIPRIS OpenAPI 키 (plus.kipris.or.kr 가입 후 발급)
KIPRIS_API_KEY=

# OpenAI API 키 (임베딩 + 신규성 분석 LLM)
OPENAI_API_KEY=

# DB 접속 URL. 미지정 시 sqlite:///./patents.db
DATABASE_URL=sqlite:///./patents.db

# CORS 허용 오리진 (쉼표 구분). 기본 "*" (모두 허용). 배포 시 도메인 화이트리스트로 교체.
CORS_ORIGINS=*

# true 로 설정 시 KIPRIS/임베딩 호출을 우회하고 mock_data 사용
USE_MOCK=false

# 레이트 리밋 (slowapi 표기). 미지정 시 아래 기본값 사용.
# 배포 환경에서 외부 API 쿼터/비용에 맞춰 조정하세요.
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_ANALYZE=10/minute
RATE_LIMIT_TREND=60/minute
RATE_LIMIT_SIMILARITY=20/minute
